rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Chaque utilisateur peut lire/écrire son propre doc
    // L'admin (zaogirardot@gmail.com) peut tout lire
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.email == 'zaogirardot@gmail.com';

      match /progress/{courseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null && request.auth.token.email == 'zaogirardot@gmail.com';
      }
    }

    // Rooms (Kahoot + Présentateur) — lisibles/écrivables par tous les utilisateurs
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
      // Présentateur screen (not authenticated) — lecture seule
      allow read: if true;
    }

    // Leaderboard — lecture pour tous les connectés, écriture uniquement par le propriétaire
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Signalements de cartes
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.email == 'zaogirardot@gmail.com';
    }

    // Suggestions d'amélioration — tout utilisateur peut créer, seul l'admin peut lire/supprimer
    match /suggestions/{suggId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && request.auth.token.email == 'zaogirardot@gmail.com';
    }

    // Signets (bookmarks) par cours — lecture/écriture par le propriétaire + admin en lecture
    match /users/{userId}/bookmarks/{courseId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.email == 'zaogirardot@gmail.com';
    }

  }
}
